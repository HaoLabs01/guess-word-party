{
  "rewrites": [
    {
      "source": "/recordings",
      "destination": "/api/recordings"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(self)"
        }
      ]
    }
  ]
}
